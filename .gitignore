# --- Node / build ---
node_modules/
dist/
.cache/
*.tsbuildinfo

# --- 環境・秘密情報 ---
.env
.env.*
!.env.example

# --- fetch スクリプトの生成物 ---
# SQLite ビルド DB・内部状態は中間生成物（再生成可能）なのでコミットしない。
# 静的配信 JSON は初回シードとして data/ をコミット対象とする。
/data/*.sqlite
/data/*.sqlite-shm
/data/*.sqlite-wal
/data/state/

# --- OS / エディタ ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# --- 確認用スクショ（一時生成物）---
/preview-shots/

# --- ログ ---
*.log
npm-debug.log*
data/.deploy-needed
