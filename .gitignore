# --- Node / build ---
node_modules/
dist/
.cache/
*.tsbuildinfo

# --- 環境・秘密情報 ---
.env
.env.*
!.env.example

# --- fetch スクリプトの生成物 ---
# 静的配信 JSON（data/*.json）は初回シードとしてコミット対象とする。
# data/series/ は 6000+ ファイルのため main ブランチ管理外（state ブランチ rsync で永続化）。
/data/state/
/data/series/

# --- OS / エディタ ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# --- SQLite 中間ファイル（安全網: SQLite 機能は廃止済みだが誤コミット防止）---
*.sqlite
*.sqlite-shm
*.sqlite-wal

# --- 確認用スクショ（一時生成物）---
/preview-shots/

# --- ログ ---
*.log
npm-debug.log*
data/.deploy-needed
